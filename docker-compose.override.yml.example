# MCPサイドカーコンテナのサンプル構成
# 使い方: このファイルを docker-compose.override.yml にコピーして編集
#   cp docker-compose.override.yml.example docker-compose.override.yml
#
# SSE/Streamable HTTP で Claude Code コンテナから接続するパターン

services:
  # 例: カスタムMCPサーバーをサイドカーとして起動
  # mcp-example:
  #   build:
  #     context: ./mcp-servers/my-server
  #   ports:
  #     - "3001:3001"
  #   environment:
  #     - MCP_PORT=3001

  # 例: PostgreSQL MCPサーバー
  # mcp-postgres:
  #   image: node:20-slim
  #   command: npx -y @modelcontextprotocol/server-postgres postgresql://postgres:password@db:5432/mydb
  #   depends_on:
  #     - db

  # 例: 外部データベース
  # db:
  #   image: postgres:16
  #   environment:
  #     POSTGRES_PASSWORD: password
  #     POSTGRES_DB: mydb
  #   volumes:
  #     - pgdata:/var/lib/postgresql/data

# volumes:
#   pgdata:
